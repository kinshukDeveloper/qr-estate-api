{
  "name": "qr-estate-backend",
  "version": "1.0.0",
  "description": "QR Real Estate Platform — Express API (Vercel + Neon)",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "lint": "eslint src --ext .js",
    "db:migrate": "psql $DATABASE_URL -f migrations/schema.sql",
    "db:seed": "node seeds/seed.js",
    "db:seed:v2": "node seeds/seed-v2.js",
    "db:seed:leads": "node seeds/seed-leads.js",
    "db:seed:v2:features": "node seeds/seed-v2-features.js",
    "db:seed:all": "npm run db:seed && npm run db:seed:v2 && npm run db:seed:leads && npm run db:seed:v2:features && npm run db:seed:v2:f456 && npm run db:seed:v2:f789",
    "db:seed:v2:f456": "node seeds/seed-v2-f456.js",
    "db:seed:v2:f789": "node seeds/seed-v2-f789.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.12.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "openai": "^4.47.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.5",
    "puppeteer": "^22.0.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.2",
    "sharp": "^0.33.3",
    "twilio": "^5.0.4",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0"
  }
}

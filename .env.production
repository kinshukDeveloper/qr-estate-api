# ─────────────────────────────────────────────────────────────
#  QR Estate — BACKEND PRODUCTION (Vercel)
#  Set these in: Vercel Dashboard → Project → Settings → Env Vars
#  NEVER commit this file with real values
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
API_VERSION=v1

# ── Neon PostgreSQL ──────────────────────────────────────────
# Get from: console.neon.tech → Connection Details → Pooled
DATABASE_URL=postgresql://<user>:<pass>@<host>.neon.tech/neondb?sslmode=require
DB_SSL=true
DB_POOL_MAX=3
DB_IDLE_TIMEOUT=10000
DB_CONNECT_TIMEOUT=10000

# ── Upstash Redis ────────────────────────────────────────────
# Get from: console.upstash.com → Redis → Connect → ioredis
REDIS_URL=rediss://default:<pass>@<host>.upstash.io:6379

# ── JWT ──────────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_ACCESS_SECRET=GENERATE_WITH_CRYPTO_64_BYTES
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_SECRET_64_BYTES
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── BCRYPT ───────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OpenAI (Feature 2 — optional) ────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxx

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
APP_URL=https://your-backend.vercel.app
SHORT_URL_BASE=https://your-backend.vercel.app/q

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# ── Twilio (Feature 4 — 60-second callback) ──────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_FROM=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
